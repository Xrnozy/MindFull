<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_background"
    tools:context=".MainActivity">

    <!-- HEADER (Non-scrolling) -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentStart="true">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="Mindfull Logo"
                android:src="@drawable/ic_leaf"
                app:tint="@color/brand_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/app_name"
                android:textColor="@color/brand_primary"
                android:textSize="24sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/logout_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_dashboard"
            app:tint="@color/brand_primary"
            android:contentDescription="Logout" />
    </RelativeLayout>

    <!-- CONTENT AREA (Scrolling support) -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="80dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <FrameLayout
            android:id="@+id/content_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- HOME SECTION -->
            <LinearLayout
                android:id="@+id/view_home"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="visible">

                <!-- User Level & XP -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/user_level_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level --"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/brand_primary" />
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />
                    <TextView
                        android:id="@+id/user_xp_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- XP"
                        android:textSize="14sp"
                        android:textColor="@color/brand_inactive" />
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/xp_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:indicatorColor="@color/brand_primary"
                    app:trackColor="@color/brand_active_pill"
                    android:progress="0" />

                <!-- Greeting -->
                <TextView
                    android:id="@+id/greeting_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Hello."
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary" />

                <!-- Mascot Advice Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/mascot_advice_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/brand_active_pill">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/mascot_image"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/coach_eagle"
                            android:scaleType="centerInside"
                            android:contentDescription="Coach Eagle" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Coach Eagle"
                                android:textStyle="bold"
                                android:textSize="12sp"
                                android:textColor="@color/brand_primary" />
                            <TextView
                                android:id="@+id/mascot_advice_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="You've solved a similar problem before. Try solving it yourself first to keep your brain sharp!"
                                android:textSize="14sp"
                                android:textColor="@color/brand_primary"
                                android:alpha="0.9" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Quick Stats -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/white"
                        android:layout_marginEnd="8dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/streak_label"
                                android:textSize="12sp"
                                android:letterSpacing="0.1"
                                android:textColor="@color/brand_inactive" />
                            <TextView
                                android:id="@+id/streak_value_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--d"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/brand_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/white"
                        android:layout_marginStart="8dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/green_points_label"
                                android:textSize="12sp"
                                android:letterSpacing="0.1"
                                android:textColor="@color/brand_inactive" />
                            <TextView
                                android:id="@+id/green_points_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/brand_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Metrics Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/metrics_title"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="12dp" />

                <!-- Grid of Metrics -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/white"
                        android:layout_margin="4dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/carbon_footprint"
                                android:textSize="12sp"
                                android:textColor="@color/brand_inactive" />
                            <TextView
                                android:id="@+id/carbon_value_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--g"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/brand_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/white"
                        android:layout_margin="4dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/water_consumption"
                                android:textSize="12sp"
                                android:textColor="@color/brand_inactive" />
                            <TextView
                                android:id="@+id/water_value_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--ml"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/brand_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/white"
                        android:layout_margin="4dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/electricity"
                                android:textSize="12sp"
                                android:textColor="@color/brand_inactive" />
                            <TextView
                                android:id="@+id/electricity_value_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--Wh"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/brand_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/white"
                        android:layout_margin="4dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/nav_coach"
                                android:textSize="12sp"
                                android:textColor="@color/brand_inactive" />
                            <TextView
                                android:id="@+id/prompts_count_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/brand_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Score Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/brand_active_pill">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/score_label"
                            android:textSize="14sp"
                            android:textColor="@color/brand_primary" />
                        <TextView
                            android:id="@+id/score_value_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="48sp"
                            android:textStyle="bold"
                            android:textColor="@color/brand_primary" />
                        <TextView
                            android:id="@+id/dependency_score_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dependency: --"
                            android:textSize="14sp"
                            android:textColor="@color/brand_primary"
                            android:alpha="0.8" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Forest Progress -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:contentDescription="Forest Icon"
                            android:src="@drawable/ic_leaf"
                            app:tint="@color/brand_primary" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/nav_forest"
                                android:textStyle="bold"
                                android:textColor="@color/brand_primary" />
                            <TextView
                                android:id="@+id/trees_planted_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-- trees planted"
                                android:textSize="12sp"
                                android:textColor="@color/brand_inactive" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- COACH SECTION -->
            <LinearLayout
                android:id="@+id/view_coach"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prompt Coach"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary" />

                <!-- User Level & XP for Coach -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/coach_user_level_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 1"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/brand_primary" />
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />
                    <TextView
                        android:id="@+id/coach_user_xp_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 XP"
                        android:textSize="12sp"
                        android:textColor="@color/brand_inactive" />
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/coach_xp_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    app:indicatorColor="@color/brand_primary"
                    app:trackColor="@color/brand_active_pill"
                    android:progress="0" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    android:hint="Type your prompt here...">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/prompt_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="3"
                        android:gravity="top"
                        android:inputType="textMultiLine" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/analyze_button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="Analyze Efficiency"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/brand_primary" />

                <ProgressBar
                    android:id="@+id/coach_loading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:indeterminate="true"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <!-- Results Container -->
                <LinearLayout
                    android:id="@+id/analysis_results_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp"
                    android:visibility="gone">

                    <!-- Score Header -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/brand_active_pill">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Efficiency Score"
                                android:textSize="14sp"
                                android:textColor="@color/brand_primary" />
                            <TextView
                                android:id="@+id/efficiency_score_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="48sp"
                                android:textStyle="bold"
                                android:textColor="@color/brand_primary" />
                            <TextView
                                android:id="@+id/model_recommendation_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Recommended: --"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/brand_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Preview Metrics Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/white"
                            android:layout_margin="4dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Token Estimate"
                                    android:textSize="11sp"
                                    android:textColor="@color/brand_inactive" />
                                <TextView
                                    android:id="@+id/token_preview_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="-- tokens"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/brand_primary" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/white"
                            android:layout_margin="4dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Carbon Estimate"
                                    android:textSize="11sp"
                                    android:textColor="@color/brand_inactive" />
                                <TextView
                                    android:id="@+id/carbon_preview_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--g CO2e"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/brand_primary" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- Feedback Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Coach Feedback"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/brand_primary"
                        android:layout_marginTop="24dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout
                            android:id="@+id/feedback_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

            <!-- THINK-A-HEAD SECTION -->
            <LinearLayout
                android:id="@+id/view_think_ahead"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Think-A-Head"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Human Intelligence Preservation"
                    android:textSize="14sp"
                    android:textColor="@color/brand_inactive"
                    android:layout_marginTop="4dp" />

                <!-- Dependency Score Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI Dependency Score"
                            android:textSize="12sp"
                            android:textColor="@color/brand_inactive" />
                        <TextView
                            android:id="@+id/think_dependency_score_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/brand_primary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lower is better for your brain health."
                            android:textSize="12sp"
                            android:textColor="@color/brand_inactive"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Reflection Tool -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reflect Before Prompting"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary"
                    android:layout_marginTop="32dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:hint="What do you want to ask AI?">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/reflection_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minLines="2"
                                android:inputType="textMultiLine" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/reflect_button"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="12dp"
                            android:text="Reflect First"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Reflection Results -->
                <LinearLayout
                    android:id="@+id/reflection_results"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/brand_active_pill">
                        <LinearLayout
                            android:id="@+id/reflection_questions_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Retention Quizzes Placeholder -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Knowledge Retention"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary"
                    android:layout_marginTop="32dp" />

                <LinearLayout
                    android:id="@+id/retention_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp" />

            </LinearLayout>

            <!-- FOREST SECTION -->
            <LinearLayout
                android:id="@+id/view_forest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_forest"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary" />

                <TextView
                    android:id="@+id/forest_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading your digital forest..."
                    android:layout_marginTop="8dp"
                    android:textColor="@color/brand_inactive" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/plant_tree_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Plant a New Tree (+ Green Points)" />

                <LinearLayout
                    android:id="@+id/trees_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Community Goals"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary"
                    android:layout_marginTop="24dp" />

                <LinearLayout
                    android:id="@+id/community_goals_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- GREENMAP SECTION -->
            <LinearLayout
                android:id="@+id/view_greenmap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GreenMap™"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Sustainability Transparency"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/brand_inactive" />

                <com.google.android.gms.maps.MapView
                    android:id="@+id/green_map_view"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="16dp" />

                <LinearLayout
                    android:id="@+id/eco_profiles_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp" />
            </LinearLayout>

            <!-- IMPACT SECTION (Hidden for now as it's the 5th or redundant) -->
            <LinearLayout
                android:id="@+id/view_impact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Impact History"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary" />
            </LinearLayout>

        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BUILT-IN BOTTOM NAVIGATION -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/brand_background"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:elevation="0dp"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:itemRippleColor="@color/brand_active_pill"
        app:indicatorColor="@color/brand_active_pill"
        app:labelVisibilityMode="labeled"
        app:itemTextAppearanceActive="@style/BottomNavText.Active"
        app:itemTextAppearanceInactive="@style/BottomNavText"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>