# MindFull Environment Variables
# Copy to .env and fill in all values before deployment

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# General
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PROJECT_NAME=MindFull
API_V1_STR=/api/v1
ENVIRONMENT=development
DOMAIN=localhost

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Security
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=your-256-bit-secret-key-change-this-in-production-mindfull-dev
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Database (PostgreSQL)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
POSTGRES_USER=mindfull
POSTGRES_PASSWORD=mindfull_dev_password
POSTGRES_DB=mindfull_db

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Redis
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
REDIS_PASSWORD=redis_dev_password
REDIS_URL=redis://:redis_dev_password@redis:6379/0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Celery
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CELERY_BROKER_URL=redis://:redis_dev_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_dev_password@redis:6379/2

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Supabase (External Auth)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Traefik
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Generate with: htpasswd -nb admin yourpassword
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$xyz$$hashedpassword
ACME_EMAIL=admin@localhost

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Grafana
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_dev_password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API Workers
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
API_WORKERS=2
