{
  "manifest_version": 3,
  "name": "MindFull Test Extension",
  "version": "1.0",
  "description": "A simple test extension for MindFull backend",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
